rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Current app collections
    match /worker_presence/{docId} {
      allow read, write: if signedIn();
    }

    match /change_logs/{docId} {
      allow read, write: if signedIn();
    }

    // Requested legacy/extra collections
    match /sessions/{docId} {
      allow read, write: if signedIn();
    }

    match /worker_activity/{docId} {
      allow read, write: if signedIn();
    }

    // Chat channel messages: /chat/{channel}/messages/{messageId}
    match /chat/{channel}/messages/{messageId} {
      allow read, write: if signedIn();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
